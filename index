<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Truyện ngắn của Celine</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    body {
      background: #0f172a;
      color: #e5e7eb;
      line-height: 1.6;
      padding: 20px;
    }

    .container {
      max-width: 800px;
      margin: 0 auto;
      background: #020617;
      border-radius: 12px;
      padding: 24px 20px 28px;
      box-shadow: 0 18px 45px rgba(15, 23, 42, 0.9);
      border: 1px solid #1f2937;
    }

    header {
      margin-bottom: 20px;
      border-bottom: 1px solid #1f2937;
      padding-bottom: 16px;
    }

    h1 {
      font-size: 1.8rem;
      color: #f97316;
      margin-bottom: 4px;
    }

    .subtitle {
      font-size: 0.9rem;
      color: #9ca3af;
    }

    .meta {
      margin-top: 8px;
      font-size: 0.8rem;
      color: #6b7280;
    }

    .tag {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 999px;
      border: 1px solid #4b5563;
      font-size: 0.7rem;
      margin-right: 6px;
    }

    .chapter-list {
      margin: 18px 0 10px;
      padding: 10px 12px;
      background: #020617;
      border-radius: 10px;
      border: 1px solid #111827;
    }

    .chapter-list h2 {
      font-size: 1rem;
      margin-bottom: 6px;
      color: #e5e7eb;
    }

    .chapter-list button {
      display: inline-block;
      margin: 4px 4px 0 0;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid #374151;
      background: #020617;
      color: #e5e7eb;
      font-size: 0.8rem;
      cursor: pointer;
      transition: all 0.15s ease;
    }

    .chapter-list button:hover {
      border-color: #f97316;
      color: #fed7aa;
    }

    .chapter-list button.active {
      background: #f97316;
      color: #111827;
      border-color: #f97316;
    }

    .chapter-title {
      font-size: 1.1rem;
      margin: 10px 0 6px;
      color: #fbbf24;
    }

    .chapter-content {
      font-size: 0.95rem;
      text-align: justify;
      color: #e5e7eb;
      white-space: pre-line;
      margin-bottom: 16px;
    }

    footer {
      margin-top: 10px;
      font-size: 0.75rem;
      color: #6b7280;
      text-align: center;
    }

    a {
      color: #f97316;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Những mảnh truyện nhỏ</h1>
      <div class="subtitle">Một góc nhỏ để Celine kể chuyện theo cách của riêng mình.</div>
      <div class="meta">
        <span class="tag">#truyện_ngắn</span>
        <span class="tag">#tản_văn</span>
        <span class="tag">#cảm_xúc</span>
      </div>
    </header>

    <section class="chapter-list">
      <h2>Chọn chương</h2>
      <div id="chapterButtons"></div>
    </section>

    <section>
      <div id="chapterTitle" class="chapter-title"></div>
      <div id="chapterContent" class="chapter-content"></div>
    </section>

    <footer>
      © <span id="year"></span> Celine. Host trên GitHub Pages.
    </footer>
  </div>

  <script>
    // Dữ liệu truyện – bạn sửa nội dung ở đây
    const chapters = [
      {
        title: "Chương 1: Đêm thành phố không ngủ",
        content: `Thành phố về đêm không hẳn là yên tĩnh, chỉ là những âm thanh đã thay đổi màu sắc.

Đèn đường vàng hắt xuống những vệt dài trên mặt đường ướt mưa. Celine bước chậm, nghe tiếng giày mình chạm vào mặt đất như một nhịp trống nhỏ, đều đều.

Có những ngày người ta không cần một câu trả lời, chỉ cần một đoạn đường đủ dài để đi, một bầu trời đủ tối để giấu hết những điều chưa kịp nói ra.`
      },
      {
        title: "Chương 2: Tin nhắn chưa gửi",
        content: `Trong hộp thư của Celine có rất nhiều tin nhắn chưa bao giờ được gửi đi.

Có tin nhắn chỉ vỏn vẹn một câu: "Cậu ổn không?". Có tin dài đến mức nếu gửi đi, chắc sẽ mất vài phút để đọc hết.

Nhưng rồi, tất cả vẫn nằm đó, như những chiếc chai thủy tinh thả trôi trong đại dương, không có người nhận, cũng chẳng có bến bờ.`
      },
      {
        title: "Chương 3: Một tách cà phê, hai người im lặng",
        content: `Quán cà phê nhỏ nằm trong con hẻm cũ, nơi thời gian dường như chậm lại một chút.

Hai người ngồi đối diện, giữa họ là một chiếc bàn gỗ, hai tách cà phê còn bốc khói. Không ai nói gì nhiều, nhưng sự im lặng không hề khó chịu.

Có những người, chỉ cần cùng ngồi đó, không cần cố gắng trở nên thú vị, cũng đã là một dạng bình yên hiếm có.`
      }
    ];

    const chapterButtonsContainer = document.getElementById("chapterButtons");
    const chapterTitleEl = document.getElementById("chapterTitle");
    const chapterContentEl = document.getElementById("chapterContent");
    const yearEl = document.getElementById("year");

    yearEl.textContent = new Date().getFullYear();

    function renderChapter(index) {
      const chapter = chapters[index];
      chapterTitleEl.textContent = chapter.title;
      chapterContentEl.textContent = chapter.content;

      document
        .querySelectorAll(".chapter-list button")
        .forEach((btn, i) => {
          btn.classList.toggle("active", i === index);
        });
    }

    function initChapters() {
      chapters.forEach((chapter, index) => {
        const btn = document.createElement("button");
        btn.textContent = `Chương ${index + 1}`;
        btn.addEventListener("click", () => renderChapter(index));
        chapterButtonsContainer.appendChild(btn);
      });

      // Mặc định mở chương 1
      if (chapters.length > 0) renderChapter(0);
    }

    initChapters();
  </script>
</body>
</html>
